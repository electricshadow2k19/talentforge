# TalentForge — environment template (copy to .env)

# Database — SQLite for local dev; PostgreSQL for production
DATABASE_URL=sqlite:///./talentforge.db
# DATABASE_URL=postgresql://talentforge:password@localhost:5432/talentforge

# Auth (required in production)
JWT_SECRET=change-me-in-production-talentforge-jwt-secret

# AI (optional — heuristic fallback when empty)
OPENAI_API_KEY=
USE_AI=true
OPENAI_MODEL=gpt-4o-mini

# CORS — set to production frontend URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# CORS_ORIGINS=https://talentforge.vercel.app

# Storage — local for dev; S3 for production
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# STORAGE_BACKEND=s3
# S3_BUCKET=talentforge-resumes
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1

# Frontend build (Vite)
VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://your-api-host.com

# Environment
ENVIRONMENT=development
